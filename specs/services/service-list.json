{
  "page": {
    "name": "Services",
    "layout": "Sidebar Layout with Header and Content Area",
    "sections": [
      {
        "id": "top-banner",
        "type": "banner",
        "components": [
          {
            "id": "verify-phone-alert",
            "type": "alert",
            "label": "Verify your Phone Number to enable Phone and SMS notifications",
            "properties": {
              "variant": "info",
              "hasCloseButton": true
            }
          }
        ]
      },
      {
        "id": "header",
        "type": "header",
        "components": [
          {
            "id": "page-title",
            "type": "typography",
            "label": "Services",
            "properties": {
              "variant": "h1"
            }
          },
          {
            "id": "page-description",
            "type": "typography",
            "label": "Services are logical units of your product/service and are mapped to alert sources. Choose from the Catalog and Graph view to understand your services, health metrics and their dependencies in detail. Read More",
            "properties": {
              "variant": "body"
            }
          },
          {
            "id": "search-button",
            "type": "button",
            "label": "",
            "properties": {
              "icon": "search",
              "variant": "outline"
            }
          },
          {
            "id": "filter-button",
            "type": "button",
            "label": "",
            "properties": {
              "icon": "filter",
              "variant": "outline"
            }
          },
          {
            "id": "add-new-service-button",
            "type": "button",
            "label": "Add New Service",
            "properties": {
              "variant": "primary"
            }
          }
        ]
      },
      {
        "id": "navigation-tabs",
