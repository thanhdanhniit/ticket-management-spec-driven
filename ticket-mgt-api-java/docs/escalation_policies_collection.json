        {
          "id": "ep-create-001",
          "name": "Create Escalation Policy",
          "request": {
            "name": "Create Escalation Policy",
            "description": {
              "content": "Creates a new escalation policy. Requires at least one step (minItems=1). Each step requires waitTimeMinutes, targetId, and targetType (USER or TEAM).",
              "type": "text/plain"
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Escalation Policy\",\n  \"description\": \"Escalates to on-call engineer, then to team lead.\",\n  \"steps\": [\n    {\n      \"waitTimeMinutes\": 0,\n      \"targetId\": \"00000000-0000-0000-0000-000000000001\",\n      \"targetType\": \"USER\"\n    },\n    {\n      \"waitTimeMinutes\": 15,\n      \"targetId\": \"00000000-0000-0000-0000-000000000010\",\n      \"targetType\": \"TEAM\"\n    }\n  ]\n}",
              "options": {
                "raw": { "headerFamily": "json", "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/escalation-policies",
              "host": ["{{baseUrl}}"],
              "path": ["escalation-policies"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set(\"policy_id\", jsonData.id);",
                  "    console.log(\"Saved policy_id: \" + jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"<uuid>\",\n  \"name\": \"New Escalation Policy\",\n  \"description\": \"Escalates to on-call engineer, then to team lead.\",\n  \"steps\": [\n    { \"id\": \"<uuid>\", \"stepOrder\": 1, \"waitTimeMinutes\": 0, \"targetId\": \"<uuid>\", \"targetType\": \"USER\" },\n    { \"id\": \"<uuid>\", \"stepOrder\": 2, \"waitTimeMinutes\": 15, \"targetId\": \"<uuid>\", \"targetType\": \"TEAM\" }\n  ]\n}",
              "cookie": [],
