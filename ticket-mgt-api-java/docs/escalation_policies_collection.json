          "request": {
            "name": "Search Escalation Policies by Name",
            "description": {
              "content": "Filters the list using the live search bar. Pass a partial name to narrow results.",
              "type": "text/plain"
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/escalation-policies?page=0&size=20&search=Critical",
              "host": ["{{baseUrl}}"],
              "path": ["escalation-policies"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "search", "value": "Critical", "description": { "content": "Partial name match", "type": "text/plain" } }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK - Filtered results",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"content\": [\n    {\n      \"id\": \"<uuid>\",\n      \"name\": \"Critical Incident Fast-Track\",\n      \"description\": \"Aggressive 2-step escalation for P0 incidents\",\n      \"steps\": []\n    }\n  ],\n  \"page\": 0,\n  \"size\": 20,\n  \"totalElements\": 1,\n  \"totalPages\": 1\n}",
              "cookie": [],
