              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"timestamp\": \"<dateTime>\",\n  \"status\": 400,\n  \"error\": \"Bad Request\",\n  \"message\": \"name: Policy name is required; steps: At least one escalation step is required\",\n  \"path\": \"/api/v1/escalation-policies\"\n}",
              "cookie": [],
              "_postman_previewlanguage": "json"
            }
          ],
          "protocolProfileBehavior": { "disableBodyPruning": true }
