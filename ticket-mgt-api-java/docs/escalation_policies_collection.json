{
  "info": {
    "name": "Escalation Policy Management API",
    "description": "Postman collection for the Escalation Policies domain. Covers full CRUD operations as defined in specs/escalation-policies-api-spec.yaml.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "bearer_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "policy_id",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearer_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Generate JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/login",
              "host": ["http://localhost:8080"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"bearer_token\", jsonData.token);",
                  "    console.log(\"Saved JWT to Collection Variables successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Escalation Policies",
      "description": "Full CRUD operations for the Escalation Policies domain.",
      "item": [
        {
          "id": "ep-list-001",
          "name": "List Escalation Policies",
          "request": {
            "name": "List Escalation Policies",
            "description": {
              "content": "Returns a paginated list of all escalation policies. Supports search filtering via the 'search' query parameter.",
              "type": "text/plain"
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/escalation-policies?page=0&size=20&sort=name,asc",
              "host": ["{{baseUrl}}"],
              "path": ["escalation-policies"],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": { "content": "Page index (0-indexed)", "type": "text/plain" }
                },
                {
                  "key": "size",
                  "value": "20",
                  "description": { "content": "Number of records per page", "type": "text/plain" }
                },
                {
                  "key": "sort",
                  "value": "name,asc",
                  "description": { "content": "Sort field and direction", "type": "text/plain" }
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true,
                  "description": { "content": "Optional: filter by policy name", "type": "text/plain" }
                }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK - Paginated list returned",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"content\": [\n    {\n      \"id\": \"<uuid>\",\n      \"name\": \"Standard On-Call Escalation\",\n      \"description\": \"Default 3-step escalation\",\n      \"steps\": [\n        { \"id\": \"<uuid>\", \"stepOrder\": 1, \"waitTimeMinutes\": 0, \"targetId\": \"<uuid>\", \"targetType\": \"USER\" },\n        { \"id\": \"<uuid>\", \"stepOrder\": 2, \"waitTimeMinutes\": 15, \"targetId\": \"<uuid>\", \"targetType\": \"TEAM\" }\n      ]\n    }\n  ],\n  \"page\": 0,\n  \"size\": 20,\n  \"totalElements\": 2,\n  \"totalPages\": 1\n}",
              "cookie": [],
              "_postman_previewlanguage": "json"
            },
            {
              "name": "500 Internal Server Error",
              "status": "Internal Server Error",
              "code": 500,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"timestamp\": \"<dateTime>\",\n  \"status\": 500,\n  \"error\": \"Internal Server Error\",\n  \"message\": \"An unexpected error occurred.\",\n  \"path\": \"/api/v1/escalation-policies\"\n}",
              "cookie": [],
              "_postman_previewlanguage": "json"
            }
